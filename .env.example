# Copy this to .env and fill in your values
DISCORD_TOKEN=your-bot-token-here
GUILD_ID=your-server-id-here

# Comma-separated channel names mapped to tags
# Format: channel_name:tag
# Tags: standup, shipped, blocker
WATCHED_CHANNELS=standup:standup,shipped:shipped,blockers:blocker

# Demo day date (YYYY-MM-DD)
DEMO_DAY=2026-05-23

# How many days to show in the activity grid
GRID_DAYS=14
